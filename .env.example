# ── OpenInterest Lens — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Database URL (TimescaleDB for production, SQLite for dev)
OIL_DATABASE_URL=postgresql+asyncpg://oil:changeme@timescaledb:5432/openinterest_lens

# Redis URL (for caching, rate limiting, WebSocket pub/sub)
OIL_REDIS_URL=redis://redis:6379/0

# Master API key for admin operations (generate a strong random key)
OIL_MASTER_API_KEY=oil_sk_live_CHANGE_ME_TO_A_STRONG_RANDOM_KEY

# ── Application ──────────────────────────────────────────────────────────────

# Environment: dev, staging, prod
OIL_ENVIRONMENT=dev

# Log level: debug, info, warning, error
OIL_LOG_LEVEL=info

# Server host and port
OIL_HOST=0.0.0.0
OIL_PORT=8000

# ── Security ────────────────────────────────────────────────────────────────

# CORS — comma-separated list of allowed origins (NO wildcards in production!)
# Production example: https://app.openinterestlens.com,https://docs.openinterestlens.com
OIL_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# CORS allowed methods
OIL_CORS_ALLOW_METHODS=GET,POST,OPTIONS

# CORS allowed headers
OIL_CORS_ALLOW_HEADERS=X-API-Key,Authorization,Content-Type,Accept

# ── Data Sources ──────────────────────────────────────────────────────────────

# CFTC API key (for COT data downloads — register at https://publicreporting.cftc.gov)
OIL_CFTC_API_KEY=

# CME Group credentials (for settlement data — optional, public data works)
OIL_CME_USERNAME=
OIL_CME_PASSWORD=

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Global rate limits per tier (requests per hour)
# Override per-endpoint limits are defined in middleware/security.py
OIL_RATE_LIMIT_FREE=100
OIL_RATE_LIMIT_PRO=1000
OIL_RATE_LIMIT_ENTERPRISE=10000

# ── Worker (Scheduler) ───────────────────────────────────────────────────────

# Set to "true" to run this instance as a worker instead of API server
OIL_WORKER_MODE=false

# ── Monitoring ────────────────────────────────────────────────────────────────

# Enable Prometheus metrics at /metrics
OIL_METRICS_ENABLED=true